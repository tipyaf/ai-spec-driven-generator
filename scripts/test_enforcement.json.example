{
  "backend_test_dirs": ["tests/"],
  "integration_test_dirs": ["tests/integration/"],
  "frontend_test_dir": "src",
  "production_dirs": ["src/", "app/"],
  "router_dirs": ["app/routers/", "src/routes/"],
  "model_dirs": ["app/models/", "src/models/"],
  "schema_files": ["schema.sql"],
  "migration_dirs": ["migrations/versions/", "prisma/migrations/"],
  "oracle_check": {
    "enabled": true,
    "write_path_keywords": ["order", "payment", "invoice", "total", "balance", "score", "rate", "price", "amount", "fee", "tax", "discount"],
    "python_search_window": 5,
    "known_files_without_oracle": []
  },
  "known_mock_files": []
}
