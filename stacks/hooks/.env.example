# SonarQube configuration — copy to .env at project root
# cp framework/stacks/hooks/.env.example .env

SONAR_TOKEN=squ_your_token_here
SONAR_HOST_URL=http://localhost:9000
SONAR_PROJECT_KEY=your-project-key

# Optional: override the base branch for diff comparison
# Auto-detected if not set (origin/develop > origin/main > origin/master)
# SONAR_BASE_BRANCH=origin/main
